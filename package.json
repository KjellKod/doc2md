{
  "name": "doc2md",
  "private": true,
  "version": "0.1.0",
  "license": "SEE LICENSE IN LICENSE",
  "type": "module",
  "workspaces": [
    "packages/core"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "generate:mac-supported-formats": "node scripts/generate-supported-formats.mjs",
    "generate:notices": "node scripts/generate-notice-inventory.mjs",
    "generate:notices:check": "node scripts/generate-notice-inventory.mjs --check",
    "prebuild:desktop": "npm run generate:mac-supported-formats",
    "build:desktop": "vite build --mode desktop",
    "build:core": "npm run build --workspace=@doc2md/core",
    "build:mac": "bash scripts/build-mac-app.sh",
    "build:dmg": "bash scripts/build-mac-dmg.sh",
    "validate:local": "bash scripts/validate-local.sh",
    "validate:mac": "bash scripts/validate-mac-local.sh",
    "lint": "eslint .",
    "test": "vitest --exclude 'tests/e2e/**'",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:core": "npm run test --workspace=@doc2md/core",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "mdast-util-to-string": "^4.0.0",
    "pdfjs-dist": "^5.7.284",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-markdown": "^10.1.0",
    "read-excel-file": "^9.0.9",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "turndown": "^7.2.4",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.60.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.9.1",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/turndown": "^5.0.5",
    "@vitejs/plugin-react": "^6.0.2",
    "eslint": "^10.4.1",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "jsdom": "^29.1.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.60.0",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
