{
  "name": "doc2md",
  "private": true,
  "version": "0.1.0",
  "license": "MIT",
  "type": "module",
  "workspaces": [
    "packages/core"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "generate:mac-supported-formats": "node scripts/generate-supported-formats.mjs",
    "prebuild:desktop": "npm run generate:mac-supported-formats",
    "build:desktop": "vite build --mode desktop",
    "build:core": "npm run build --workspace=@doc2md/core",
    "build:mac": "bash scripts/build-mac-app.sh",
    "build:dmg": "bash scripts/build-mac-dmg.sh",
    "lint": "eslint .",
    "test": "vitest --exclude tests/e2e/**",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:core": "npm run test --workspace=@doc2md/core",
    "typecheck": "tsc --noEmit",
    "preview": "vite preview"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "lucide-react": "^1.7.0",
    "mammoth": "^1.12.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-markdown": "^9.1.0",
    "read-excel-file": "^7.0.3",
    "remark-gfm": "^4.0.1",
    "turndown": "^7.2.1"
  },
  "devDependencies": {
    "@eslint/js": "^9.23.0",
    "@playwright/test": "^1.59.1",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.3.0",
    "@types/node": "^25.5.0",
    "@types/react": "^18.3.18",
    "@types/react-dom": "^18.3.5",
    "@types/turndown": "^5.0.5",
    "@vitejs/plugin-react": "^6.0.1",
    "eslint": "^9.23.0",
    "eslint-plugin-react-hooks": "^5.2.0",
    "eslint-plugin-react-refresh": "^0.4.19",
    "jsdom": "^26.0.0",
    "typescript": "^5.8.2",
    "typescript-eslint": "^8.28.0",
    "vite": "^8.0.3",
    "vitest": "^4.1.2"
  }
}
