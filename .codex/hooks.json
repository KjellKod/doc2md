{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"[quest-audit] $(date -Iseconds) Write/Edit: $TOOL_INPUT\" >> .quest/audit.log 2>/dev/null || true"
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "'/Users/kjell/ws/extra/doc2md/.codex/hooks/session-start.sh'"
          }
        ]
      }
    ]
  }
}
