{
  "name": "@doc2md/core",
  "version": "1.0.1",
  "description": "Publish-ready Node API and CLI for doc2md document-to-markdown conversion.",
  "license": "MIT",
  "type": "module",
  "private": false,
  "homepage": "https://kjellkod.github.io/doc2md/",
  "bugs": {
    "url": "https://github.com/KjellKod/doc2md/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/KjellKod/doc2md.git",
    "directory": "packages/core"
  },
  "keywords": [
    "doc2md",
    "markdown",
    "document-conversion",
    "pdf",
    "docx",
    "cli"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist",
    "bin"
  ],
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "doc2md": "bin/doc2md.js"
  },
  "scripts": {
    "build": "vite build --config vite.config.ts && node ./scripts/copy-public-types.mjs",
    "pack:local": "node ./scripts/pack-local-release.mjs",
    "prepack": "npm run build",
    "test": "vitest run --config vitest.config.ts"
  },
  "dependencies": {
    "jszip": "^3.10.1",
    "jsdom": "^29.1.1",
    "mammoth": "^1.12.0",
    "mdast-util-to-string": "^4.0.0",
    "pdfjs-dist": "^6.0.227",
    "read-excel-file": "^9.2.0",
    "rehype-slug": "^6.0.0",
    "rehype-stringify": "^10.0.1",
    "remark-gfm": "^4.0.1",
    "remark-parse": "^11.0.0",
    "remark-rehype": "^11.1.2",
    "turndown": "^7.2.4",
    "unified": "^11.0.5",
    "unist-util-visit": "^5.1.0"
  }
}
